# --- NVIDIA NIM target ---
# Hosted NVIDIA endpoint. Sign up free (no credit card) at build.nvidia.com,
# then generate a key at https://build.nvidia.com/settings/api-keys
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For a self-hosted NIM container instead, e.g.:
# NIM_BASE_URL=http://localhost:8001/v1
# NIM_API_KEY=

# --- Proxy-side auth (optional) ---
# If set, clients must send this value as their OpenAI api_key.
# Leave blank to accept any key (fine for local dev, NOT for production).
PROXY_API_KEY=

# --- Model name mapping (OpenAI name -> NIM name) ---
# Leave unset/blank to use the built-in default map in config.py, which
# points common OpenAI model names at NVIDIA NIM's currently-free models
# (see FREE_NIM_MODELS in config.py, or GET /free-models once running).
# Set this to fully override the defaults, e.g. to pin exact model IDs or
# add embeddings:
# MODEL_MAP_JSON={"gpt-4o":"z-ai/glm-5.2","gpt-4o-mini":"mistralai/mistral-medium-3.5-128b","text-embedding-3-small":"nvidia/nv-embedqa-e5-v5"}
MODEL_MAP_JSON=

PASSTHROUGH_UNMAPPED_MODELS=true
# Blank = use DEFAULT_FREE_MODEL from config.py (currently z-ai/glm-5.2)
DEFAULT_MODEL=

REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=2

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
