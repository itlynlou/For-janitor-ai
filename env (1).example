# Server
PORT=3000
LOG_LEVEL=info
# "pretty" for human-readable local dev logs, "json" for production
LOG_FORMAT=pretty

# Default upstream used when a requested model isn't found in config/models.json.
# Useful so you don't have to register every model up front.
# DEFAULT_BACKEND: "cloud" or "selfhosted"
DEFAULT_BACKEND=cloud
DEFAULT_BASE_URL=https://integrate.api.nvidia.com/v1

# API key used for the NVIDIA cloud backend (https://integrate.api.nvidia.com).
# Referenced by name from config/models.json / config/backends.json via "apiKeyEnv".
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API keys for any self-hosted NIM containers you run behind auth.
# Add as many NIM_KEY_* vars as you need and reference them by name in backends.json.
# Most self-hosted NIM containers don't require a key at all -- leave unset if so.
NIM_KEY_LOCAL=

# Retry behavior for upstream requests (non-streaming, or before the stream opens)
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=300
RETRY_MAX_DELAY_MS=4000

# Upstream request timeout (ms) for non-streaming calls
UPSTREAM_TIMEOUT_MS=60000
